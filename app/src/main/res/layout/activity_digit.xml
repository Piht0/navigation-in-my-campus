<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_gray">

    <!-- Заголовок -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/tsu_blue_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingEnd="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Распознавание цифры"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/bg_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Нарисуй цифру от 0 до 9 на сетке 5×5"
                android:textSize="13sp"
                android:textColor="#BBCCDD"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnCloseDigit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="@color/bg_white"
            android:gravity="center" />
    </FrameLayout>

    <!-- Контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Сетка для рисования 5×5 -->
        <com.campus.navigator.DigitDrawView
            android:id="@+id/digitDrawView"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginBottom="24dp" />

        <!-- Результат -->
        <TextView
            android:id="@+id/tvDigitResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="@color/tsu_blue"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDigitConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Кнопки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnRecognize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Распознать"
                android:backgroundTint="@color/tsu_blue"
                android:textColor="@color/bg_white" />

            <Button
                android:id="@+id/btnClearDigit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Очистить"
                android:backgroundTint="@color/bg_gray"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvModelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</LinearLayout>
